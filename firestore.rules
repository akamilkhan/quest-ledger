rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: questLedger
    // Document ID: {userId} (matches the user's Auth UID)
    // Fields:
    //   - state: string (required) - Stringified JSON representing the full app state (budget, transactions, players)
    //   - lastUpdated: timestamp (required) - Server timestamp when the document was last updated
    //   - uid: string (required) - The user's Auth UID (must match userId and request.auth.uid)
    //   - ownerEmail: string (optional) - The email address of the ledger owner
    //   - memberEmails: list of strings (optional) - List of emails allowed to sync this budget
    //
    // ===============================================================

    // Check if the user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Check if the user owns the resource path
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Check if the user's verified email is in the document's memberEmails list
    function isEmailMember(data) {
      return 'memberEmails' in data && data.memberEmails is list && request.auth.token.email in data.memberEmails;
    }

    // Validate that the document contains only the allowed fields
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Validate required fields exist
    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    // Verify UID matches auth user on creation
    function isUidValidOnCreate() {
      return request.resource.data.uid == request.auth.uid;
    }

    // Verify UID is unchanged on updates
    function isUidUnchanged() {
      return request.resource.data.uid == resource.data.uid;
    }

    // Validate that lastUpdated is a timestamp
    function isLastUpdatedValid() {
      return request.resource.data.lastUpdated is timestamp;
    }

    // Domain validator for the questLedger document
    function isValidStateDoc() {
      return hasRequiredFields(['state', 'lastUpdated', 'uid']) &&
             hasOnlyAllowedFields(['state', 'lastUpdated', 'uid', 'ownerEmail', 'memberEmails']) &&
             request.resource.data.state is string &&
             request.resource.data.state.size() > 0 &&
             request.resource.data.state.size() <= 1048576 && // Limit state payload to 1MB
             isLastUpdatedValid();
    }

    // Matches the questLedger collection
    match /questLedger/{userId} {
      allow get: if isOwner(userId) || (isAuthenticated() && isEmailMember(resource.data));
      allow list: if isAuthenticated();
      
      allow create: if (isOwner(userId) || (isAuthenticated() && isEmailMember(request.resource.data)))
                    && isUidValidOnCreate()
                    && isValidStateDoc();
                    
      allow update: if (isOwner(userId) || (isAuthenticated() && isEmailMember(resource.data)))
                    && isUidUnchanged()
                    && isValidStateDoc();
                    
      allow delete: if isOwner(userId);
    }
  }
}
